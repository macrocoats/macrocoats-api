{
  "name": "macrocoats-api",
  "version": "1.0.0",
  "private": true,
  "description": "Macro Coats Product Document Portal — REST API (Fastify + Drizzle + PostgreSQL)",
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "node --import tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --import tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --import tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --import tsx node_modules/drizzle-kit/bin.cjs studio",
    "db:reset": "tsx --env-file=.env.local src/seed/reset.ts",
    "seed": "tsx --env-file=.env.local src/seed/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.3",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.29.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
