{{!--
  Mirrors safteyDataSheet/src/pages/Products/TDSPage.jsx's print-only body
  (the .tds-print-doc block) exactly — same sections, same order, same copy.
  Header/company letterhead is NOT here; it's rendered as the Puppeteer page
  header by buildPrintMatchedHeader() in pdf.service.ts, same as the footer.
--}}
<div class="document tds-print-doc">

  {{!-- ═══ PRODUCT DESCRIPTION ═══════════════════════════════════════════════ --}}
  {{#if description}}
  <div class="tds-print-section no-break">
    <div class="tds-print-section-head">Product Description</div>
    <p class="tds-print-description"><strong>{{productName}}</strong> {{description}}</p>
  </div>
  {{/if}}

  {{!-- ═══ KEY FEATURES & BENEFITS  |  TYPICAL APPLICATIONS ═════════════════ --}}
  {{#if (or sections.features sections.performance)}}
  <div class="tds-print-two-col">
    {{#if sections.features}}
    <div>
      <div class="tds-print-section-head">Key Features &amp; Benefits</div>
      <ul class="tds-print-bullet-list">
        {{#each sections.features}}
        <li><strong>{{head}}:</strong> {{body}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
    {{#if sections.performance}}
    <div>
      <div class="tds-print-section-head">Typical Applications</div>
      <ul class="tds-print-bullet-list">
        {{#each sections.performance}}
        <li><strong>{{label}}:</strong> {{val}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
  </div>
  {{/if}}

  {{!-- ═══ TYPICAL TECHNICAL SPECIFICATIONS ═════════════════════════════════ --}}
  {{#if sections.physicalProperties}}
  <div class="tds-print-section">
    <div class="tds-print-section-head">Typical Technical Specifications</div>
    <table class="tds-print-spec-table">
      <thead>
        <tr>
          <th>Property Parameter</th>
          <th>Test Method</th>
          <th>Typical Value Range</th>
        </tr>
      </thead>
      <tbody>
        {{#each sections.physicalProperties}}
        <tr>
          <td class="tds-spec-prop">{{property}}</td>
          <td class="tds-spec-method">{{#if method}}{{method}}{{else}}—{{/if}}</td>
          <td class="tds-spec-value">{{value}}{{#if unit}} {{unit}}{{/if}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{!-- ═══ APPLICATION NOTE CALLOUT ══════════════════════════════════════════ --}}
  {{#if sections.safetyNote}}
  <div class="tds-print-app-note no-break">
    <strong>Application Note:</strong> {{sections.safetyNote}}
  </div>
  {{/if}}

  {{!-- ═══ PACKAGING, STORAGE & SAFETY ═══════════════════════════════════════ --}}
  {{#if sections.packaging}}
  <div class="tds-print-section no-break">
    <div class="tds-print-section-head">Packaging, Storage &amp; Safety</div>
    <ul class="tds-print-bullet-list">
      {{#each sections.packaging}}
      <li><strong>{{type}}:</strong> Available in {{size}} {{unit}} containers.</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

</div>
