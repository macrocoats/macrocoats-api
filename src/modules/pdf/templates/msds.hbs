{{!--
  Mirrors safteyDataSheet/src/pages/Products/MSDSPage.jsx's print-only body
  (the .msds-print-doc block) exactly — same 16 GHS sections, same order,
  same copy. Header/company letterhead is NOT here; it's rendered as the
  Puppeteer page header by buildPrintMatchedHeader() in pdf.service.ts, same
  as the footer. hStmts / pGroupsPrevention|Response|Storage|Disposal /
  isSimpleComposition / physicalPaired / effectiveSignalWord are precomputed
  server-side in buildMsdsContext() (pdf.service.ts), mirroring the frontend
  component's derived values.
--}}
<div class="document msds-print-doc">

  {{!-- ═══ SECTION 1 — IDENTIFICATION ═══════════════════════════════════════ --}}
  <div class="msds-print-section no-break">
    <div class="msds-print-section-head">1. Identification of the Substance and Company</div>
    <table class="msds-print-kv-table">
      <tbody>
        <tr><td class="msds-kv-key">Product Name</td><td class="msds-kv-val msds-kv-bold">{{productName}}</td></tr>
        <tr><td class="msds-kv-key">Product Nature</td><td class="msds-kv-val">{{sections.identification.productType}}</td></tr>
        <tr><td class="msds-kv-key">Recommended Use</td><td class="msds-kv-val">{{sections.identification.intendedUse}}</td></tr>
        <tr><td class="msds-kv-key">Manufacturer</td><td class="msds-kv-val">{{sections.identification.manufacturer}}</td></tr>
        {{#if sections.identification.emergency}}
        <tr><td class="msds-kv-key">Emergency Telephone</td><td class="msds-kv-val msds-kv-accent">{{sections.identification.emergency}}</td></tr>
        {{/if}}
      </tbody>
    </table>
  </div>

  {{!-- ═══ SECTION 2 — HAZARD(S) IDENTIFICATION ═════════════════════════════ --}}
  <div class="msds-print-section">
    <div class="msds-print-section-head">2. Hazard(s) Identification</div>
    <div class="msds-hazard-card">

      <div class="msds-hazard-signal">SIGNAL WORD: {{effectiveSignalWord}}</div>

      {{#if sections.hazards.pictograms}}
      <div class="msds-hazard-pictos">
        {{#each sections.hazards.pictograms}}
        <div class="msds-hazard-picto">{{ghsDiamond this}}</div>
        {{/each}}
      </div>
      {{/if}}

      {{#if hStmts}}
      <div class="msds-hazard-group">
        <div class="msds-hazard-group-head">Hazard Statements:</div>
        <ul class="msds-hazard-stmts">
          {{#each hStmts}}
          <li><strong>{{code}}:</strong> {{text}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if pGroupsPrevention}}
      <div class="msds-hazard-group">
        <div class="msds-hazard-group-head">Precautionary Statements (Prevention):</div>
        <ul class="msds-hazard-stmts">
          {{#each pGroupsPrevention}}
          <li><strong>{{code}}:</strong> {{text}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if pGroupsResponse}}
      <div class="msds-hazard-group">
        <div class="msds-hazard-group-head">Precautionary Statements (Response):</div>
        <ul class="msds-hazard-stmts">
          {{#each pGroupsResponse}}
          <li><strong>{{code}}:</strong> {{text}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if pGroupsStorage}}
      <div class="msds-hazard-group">
        <div class="msds-hazard-group-head">Precautionary Statements (Storage):</div>
        <ul class="msds-hazard-stmts">
          {{#each pGroupsStorage}}
          <li><strong>{{code}}:</strong> {{text}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if pGroupsDisposal}}
      <div class="msds-hazard-group">
        <div class="msds-hazard-group-head">Precautionary Statements (Disposal):</div>
        <ul class="msds-hazard-stmts">
          {{#each pGroupsDisposal}}
          <li><strong>{{code}}:</strong> {{text}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

    </div>
  </div>

  {{!-- ═══ SECTION 3 — COMPOSITION ═══════════════════════════════════════════ --}}
  <div class="msds-print-section">
    <div class="msds-print-section-head">3. Composition / Information on Ingredients</div>
    <table class="msds-print-comp-table">
      <thead>
        <tr>
          {{#unless isSimpleComposition}}<th>Component / Chemical Name</th>{{/unless}}
          <th>Industrial Function</th>
          <th>Classification</th>
        </tr>
      </thead>
      <tbody>
        {{#each sections.composition.ingredients}}
        <tr>
          {{#unless ../isSimpleComposition}}<td class="msds-comp-name">{{#if name}}{{name}}{{else}}—{{/if}}</td>{{/unless}}
          <td>{{description}}</td>
          <td>{{ghsClass}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{#if sections.composition.note}}<p class="msds-print-note">{{sections.composition.note}}</p>{{/if}}
  </div>

  {{!-- ═══ SECTION 4 — FIRST AID ════════════════════════════════════════════ --}}
  <div class="msds-print-section no-break">
    <div class="msds-print-section-head">4. First-Aid Measures</div>
    <table class="msds-print-kv-table">
      <tbody>
        <tr><td class="msds-kv-key">Eye Contact</td><td class="msds-kv-val">{{sections.firstAid.eyes}}</td></tr>
        <tr><td class="msds-kv-key">Skin Contact</td><td class="msds-kv-val">{{sections.firstAid.skin}}</td></tr>
        <tr><td class="msds-kv-key">Inhalation</td><td class="msds-kv-val">{{sections.firstAid.inhalation}}</td></tr>
        <tr><td class="msds-kv-key">Ingestion</td><td class="msds-kv-val">{{sections.firstAid.ingestion}}</td></tr>
      </tbody>
    </table>
    {{#if sections.firstAid.warning}}
    <div class="msds-print-callout msds-print-callout-danger">
      <div class="msds-callout-head">Critical Notice for Intensive Medicine:</div>
      <div>{{sections.firstAid.warning}}</div>
    </div>
    {{/if}}
  </div>

  {{!-- ═══ SECTION 5 — FIRE-FIGHTING ═════════════════════════════════════════ --}}
  <div class="msds-print-section no-break">
    <div class="msds-print-section-head">5. Fire-Fighting Measures</div>
    <table class="msds-print-kv-table">
      <tbody>
        <tr><td class="msds-kv-key">Flammability Level</td><td class="msds-kv-val">{{sections.fireFighting.flammability}}</td></tr>
        <tr><td class="msds-kv-key">Extinguishing Media</td><td class="msds-kv-val">{{sections.fireFighting.extinguishingMedia}}</td></tr>
        <tr><td class="msds-kv-key">Fire Hazard</td><td class="msds-kv-val msds-kv-danger">{{sections.fireFighting.fireHazard}}</td></tr>
        <tr><td class="msds-kv-key">Firefighter PPE</td><td class="msds-kv-val">{{sections.fireFighting.ppe}}</td></tr>
      </tbody>
    </table>
  </div>

  {{!-- ═══ SECTION 6 — ACCIDENTAL RELEASE ═══════════════════════════════════ --}}
  <div class="msds-print-section">
    <div class="msds-print-section-head">6. Accidental Release Measures</div>
    <ul class="msds-print-bullet-list">
      {{#each sections.accidentalRelease}}<li>{{this}}</li>{{/each}}
    </ul>
  </div>

  {{!-- ═══ SECTION 7 — HANDLING & STORAGE ═══════════════════════════════════ --}}
  <div class="msds-print-section no-break">
    <div class="msds-print-section-head">7. Handling and Storage</div>
    <table class="msds-print-kv-table">
      <tbody>
        <tr><td class="msds-kv-key">Handling</td><td class="msds-kv-val">{{sections.handling.handling}}</td></tr>
        <tr><td class="msds-kv-key">Storage Temperature</td><td class="msds-kv-val">{{sections.handling.storageTemp}}</td></tr>
        <tr><td class="msds-kv-key">Shelf Life</td><td class="msds-kv-val">{{sections.handling.shelfLife}}</td></tr>
        {{#if sections.handling.containers}}<tr><td class="msds-kv-key">Containers</td><td class="msds-kv-val">{{sections.handling.containers}}</td></tr>{{/if}}
        {{#if sections.handling.segregation}}<tr><td class="msds-kv-key">Segregation</td><td class="msds-kv-val">{{sections.handling.segregation}}</td></tr>{{/if}}
      </tbody>
    </table>
  </div>

  {{!-- ═══ SECTION 8 — EXPOSURE CONTROLS ═════════════════════════════════════ --}}
  <div class="msds-print-section">
    <div class="msds-print-section-head">8. Exposure Controls / Personal Protection</div>
    {{#if sections.exposure.ppeItems}}
    <ul class="msds-print-bullet-list">
      {{#each sections.exposure.ppeItems}}<li>{{this}}</li>{{/each}}
    </ul>
    {{/if}}
    {{#if sections.exposure.engineering}}
    <div class="msds-print-callout">
      <div class="msds-callout-head">Engineering Controls:</div>
      <div>{{sections.exposure.engineering}}</div>
    </div>
    {{/if}}
  </div>

  {{!-- ═══ SECTION 9 — PHYSICAL PROPERTIES (4-col paired grid) ══════════════ --}}
  <div class="msds-print-section">
    <div class="msds-print-section-head">9. Physical and Chemical Properties</div>
    <table class="msds-print-phys-table">
      <tbody>
        {{#each physicalPaired}}
        <tr>
          <td class="msds-phys-key">{{a.key}}</td>
          <td class="msds-phys-val">{{a.val}}</td>
          <td class="msds-phys-key">{{b.key}}</td>
          <td class="msds-phys-val msds-phys-val-last">{{b.val}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  {{!-- ═══ SECTION 10 — STABILITY ═══════════════════════════════════════════ --}}
  <div class="msds-print-section no-break">
    <div class="msds-print-section-head">10. Stability and Reactivity</div>
    <table class="msds-print-kv-table">
      <tbody>
        <tr><td class="msds-kv-key">Stability</td><td class="msds-kv-val">{{sections.stability.stability}}</td></tr>
        <tr><td class="msds-kv-key">Conditions to Avoid</td><td class="msds-kv-val">{{sections.stability.avoid}}</td></tr>
        <tr><td class="msds-kv-key">Polymerisation</td><td class="msds-kv-val">{{sections.stability.polymerisation}}</td></tr>
        <tr><td class="msds-kv-key">Hazardous Decomposition</td><td class="msds-kv-val msds-kv-danger">{{sections.stability.decomposition}}</td></tr>
      </tbody>
    </table>
  </div>

  {{!-- ═══ SECTIONS 11–16 ═══════════════════════════════════════════════════ --}}
  {{#each sections11to16Entries}}
  <div class="msds-print-section">
    <div class="msds-print-section-head">{{number}}. {{key}}</div>
    <p class="msds-print-para">{{value}}</p>
  </div>
  {{/each}}

</div>
