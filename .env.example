# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_VERSION=v1
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/macrocoats

# ─── Redis (optional — disables document caching if not set) ─────────────────
# REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate RS256 keypair:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Then base64-encode each file:
#   base64 -i private.pem | tr -d '\n'
#   base64 -i public.pem  | tr -d '\n'
JWT_PRIVATE_KEY_B64=<base64-encoded-private-key>
JWT_PUBLIC_KEY_B64=<base64-encoded-public-key>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Cookie ───────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
COOKIE_SECRET=<random-64-char-hex>
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false          # true in production

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT_MAX=10        # max attempts per window
AUTH_RATE_LIMIT_WINDOW=900    # window in seconds (15 min)

# ─── SMTP (optional — for sending quotation emails) ──────────────────────────
# SMTP_HOST=smtp.macrocoats.in
# SMTP_PORT=587
# SMTP_USER=noreply@macrocoats.in
# SMTP_PASS=
