NODE_ENV=production
PORT={{ api_port }}
API_VERSION=v1
LOG_LEVEL=info

DATABASE_URL=postgresql://{{ db_user }}:{{ vault_db_password }}@localhost:5432/{{ db_name }}

PROCUREMENT_STORAGE_PATH={{ app_dir }}/company-documents

{% if install_redis %}
REDIS_URL=redis://localhost:6379
{% endif %}

JWT_PRIVATE_KEY_B64={{ vault_jwt_private_key_b64 }}
JWT_PUBLIC_KEY_B64={{ vault_jwt_public_key_b64 }}
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

COOKIE_SECRET={{ vault_cookie_secret }}
COOKIE_DOMAIN={{ cookie_domain }}
COOKIE_SECURE=true

ALLOWED_ORIGIN={{ frontend_origin }}

AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=900

PDF_BROWSER_POOL_SIZE=3
PDF_PAGE_TIMEOUT_MS=30000
PDF_RENDER_TIMEOUT_MS=60000

ZOHO_CLIENT_ID={{ vault_zoho_client_id }}
ZOHO_CLIENT_SECRET={{ vault_zoho_client_secret }}
ZOHO_REFRESH_TOKEN={{ vault_zoho_refresh_token }}
ZOHO_ORG_ID={{ vault_zoho_org_id }}
